# =============================================================
#  Zsh config - dotfiles (claudio1code)
#  Foco: produtividade, leveza e zero dependencia quebrada.
#  Todas as integracoes sao guardadas: se a ferramenta nao
#  estiver instalada, a linha e ignorada (nada de erro no boot).
# =============================================================

# --- PATH ---
export PATH="$HOME/.local/bin:$PATH"
[ -d "$HOME/.venv/bin" ] && export PATH="$PATH:$HOME/.venv/bin"

# --- ZINIT (gerenciador de plugins, carregamento leve) ---
ZINIT_HOME="$HOME/.local/share/zinit/zinit.git"
if [ -f "$ZINIT_HOME/zinit.zsh" ]; then
    source "$ZINIT_HOME/zinit.zsh"
    zinit light zsh-users/zsh-autosuggestions
    zinit light zsh-users/zsh-syntax-highlighting
fi

# --- COMPLETIONS ---
autoload -Uz compinit && compinit -C
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# --- ALIASES DE FERRAMENTAS (com fallback) ---
# eza (ls moderno) -> cai para ls se nao existir
if command -v eza >/dev/null 2>&1; then
    alias ls='eza --icons --group-directories-first'
    alias l='eza -l --icons --group-directories-first'
    alias la='eza -la --icons --group-directories-first'
    alias lt='eza --tree --level=2 --icons'
else
    alias ls='ls --color=auto'
    alias l='ls -l'
    alias la='ls -la'
fi

# bat (cat com highlight). No apt o binario chama-se batcat.
if command -v bat >/dev/null 2>&1; then
    alias cat='bat --paging=never'
elif command -v batcat >/dev/null 2>&1; then
    alias bat='batcat'
    alias cat='batcat --paging=never'
fi

# fd (find moderno). No apt o binario chama-se fdfind.
if ! command -v fd >/dev/null 2>&1 && command -v fdfind >/dev/null 2>&1; then
    alias fd='fdfind'
fi

alias ç='clear'
alias gs='git status'
alias gl='git log --oneline --graph --decorate -20'

# --- ZOXIDE (cd inteligente) ---
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"

# --- FZF (busca fuzzy) ---
# fzf >= 0.48 gera a integracao do shell direto; sem arquivos soltos.
if command -v fzf >/dev/null 2>&1; then
    source <(fzf --zsh) 2>/dev/null
fi

# --- NVM (Node) ---
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"

# --- SEGREDOS LOCAIS (opcional) ---
# Crie ~/.env para chaves/API tokens que nao devem ir ao repo.
[ -f "$HOME/.env" ] && source "$HOME/.env"

# --- ESTILO DO PROMPT (Dracula + Git) ---
autoload -U colors && colors
autoload -Uz vcs_info
setopt prompt_subst
zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git*' formats '%F{#bd93f9}%b%f%F{#50fa7b}%u%f%F{#8be9fd}%a%f%F{#ff5555}%m%f'
precmd() { vcs_info }
PS1=$'%B%F{#50fa7b}╭─%n@%m %F{#ff5555}[%F{#bd93f9}%2~%F{#ff5555}]%f%b ${vcs_info_msg_0_}%B%(?..[%F{#ff5555}%?%f])%b\n%F{#50fa7b}╰─➤%f '
export RPROMPT='%F{#8be9fd}%*%f'

# --- HISTORICO ---
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory sharehistory hist_ignore_dups hist_ignore_space

# --- KEYBINDINGS (Ctrl+setas = pular palavra) ---
bindkey '^[[1;5D' backward-word
bindkey '^[[1;5C' forward-word

# =============================================================
#  INTELIGENCIA ARTIFICIAL (GitHub Models - gratuito)
#  Usa 'gh models', incluso no GitHub CLI sem custo nem chave de
#  API: basta estar logado no gh (gh auth login). Substitui o
#  antigo fluxo do Gemini (auth descontinuada).
#  Modelo configuravel via GH_MODELS_DEFAULT.
# =============================================================
export GH_MODELS_DEFAULT="${GH_MODELS_DEFAULT:-openai/gpt-4o-mini}"

# Pergunta rapida no terminal:  ai "como listo portas abertas?"
if command -v gh >/dev/null 2>&1; then
    ai() { gh models run "$GH_MODELS_DEFAULT" "$*"; }
fi

# gcommit: gera mensagem de commit (Conventional Commits) a partir
# do que esta no stage, usando GitHub Models (gratuito).
gcommit() {
    if ! command -v gh >/dev/null 2>&1; then
        echo "gh (GitHub CLI) nao encontrado. Instale e rode 'gh auth login'."
        return 1
    fi
    if ! gh extension list 2>/dev/null | grep -q 'github/gh-models'; then
        echo "Instalando extensao gh-models (uma vez)..."
        gh extension install github/gh-models >/dev/null 2>&1
    fi
    if git diff --cached --quiet; then
        echo "Nada estagiado para commit (use 'git add')."
        return 1
    fi
    local diff prompt msg
    diff="$(git diff --cached)"
    prompt="Aja como um formatador de texto. Escreva UMA mensagem de commit no padrao Conventional Commits (ex: 'feat: ...', 'fix: ...') baseada apenas no diff abaixo. REGRAS: responda APENAS com a string da mensagem; sem aspas; sem explicacao; sem markdown; NAO use emojis nem gitmoji.

DIFF:
$diff"
    echo "Gerando sugestao de commit (GitHub Models: $GH_MODELS_DEFAULT)..."
    msg="$(printf '%s' "$prompt" | gh models run "$GH_MODELS_DEFAULT" 2>/dev/null)"
    # remove eventuais aspas, espacos nas pontas e emojis no inicio da linha
    msg="$(printf '%s' "$msg" | sed -e 's/^["'\'' ]*//' -e 's/["'\'' ]*$//' | head -1)"
    if [ -z "$msg" ]; then
        echo "Nao foi possivel gerar a mensagem."
        return 1
    fi
    echo "----------------------------------------"
    echo "Sugestao: $msg"
    echo "----------------------------------------"
    echo -n "Usar essa mensagem? [y/N] "
    local resp; read -r resp
    if [[ "$resp" =~ ^[Yy]$ ]]; then
        git commit -m "$msg"
    else
        echo "Cancelado."
    fi
}
